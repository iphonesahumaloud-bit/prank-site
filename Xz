<!DOCTYPE html>
<html>
<head>
<title>Security Alert</title>
</head>

<body style="background:black; color:red; text-align:center; font-family:sans-serif;">

<h1>⚠️ WARNING!</h1>
<h2>Your Device Has Been Infected</h2>
<p>Virus detected... Do not exit!</p>

<button onclick="enterFullScreen()">Start Scan</button>
<br><br>
<button onclick="stopPrank()" style="padding:10px; background:green; color:white;">
Exit
</button>

<script>
let alertInterval;

// Start prank
function enterFullScreen() {
  document.documentElement.requestFullscreen();

  alertInterval = setInterval(() => {
    alert("⚠️ Virus spreading... Do not close!");
  }, 3000);
}

// Stop prank
function stopPrank(){
  clearInterval(alertInterval);
  document.exitFullscreen();
  alert("😂 Relax , prank tha!");
}
</script>

</body>
</html>
